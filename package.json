{
  "name": "@clerk/cli",
  "version": "0.0.1",
  "description": "Clerk CLI",
  "type": "module",
  "bin": {
    "clerk": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun build ./src/cli.ts --outfile ./dist/cli.js --target node",
    "dev": "bun run ./src/cli.ts",
    "test": "bun test",
    "lint": "oxlint src/",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "prepare": "git config core.hooksPath .hooks"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.2.0",
    "commander": "^14.0.3",
    "yaml": "^2.8.2"
  }
}
